# Session + admin (see docs)
IRON_SESSION_PASSWORD=
ADMIN_PASSWORD=

# Google sign-in (from Google Cloud → APIs & Services → Credentials → OAuth 2.0 Client ID)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Base URL used to build the OAuth redirect URI (${APP_BASE_URL}/api/auth/google/callback)
APP_BASE_URL=http://localhost:3000
